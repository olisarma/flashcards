<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="400.0" prefWidth="600.0"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fi.jyu.ohj2.olisarma.flashcards.PracticeController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <children>
        <Label fx:id="pakkaNimiLabel" text="Harjoittelupakka" />

        <VBox alignment="CENTER" spacing="10.0"
              style="-fx-border-color: black; -fx-padding: 20; -fx-background-color: white;">
            <children>
                <Label text="Termi:" />
                <Label fx:id="termiLabel"
                       style="-fx-font-size: 30px; -fx-font-weight: bold;"
                       text="dog" />

                <Label text="Selitys:" />
                <Label fx:id="selitysLabel"
                       style="-fx-font-size: 20px;"
                       text="Selitys piilotettu" />
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleEdellinen" text="Edellinen" />
                <Button mnemonicParsing="false" onAction="#handleKaannaKortti" text="Käännä kortti" />
                <Button mnemonicParsing="false" onAction="#handleSeuraava" text="Seuraava" />
            </children>
        </HBox>
    </children>
</VBox>